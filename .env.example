# Meta Ads MCP Server Configuration
# Copy this file to .env and fill in your credentials

# Required: Meta API access token
META_ACCESS_TOKEN=your_access_token_here

# Required: Meta App credentials
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# Optional: Default ad account ID (with act_ prefix)
META_DEFAULT_AD_ACCOUNT_ID=act_your_account_id

# Optional: Meta Graph API version (default: v21.0)
META_API_VERSION=v25.0
